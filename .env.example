# ── Composio ──────────────────────────────────────────────────────────────────
# Free API key: https://app.composio.dev → Settings → API Keys
COMPOSIO_API_KEY=
COMPOSIO_ENTITY_ID=default
# Advanced: override if using a self-hosted Composio instance
COMPOSIO_BASE_URL=https://backend.composio.dev

# ── Gmail ─────────────────────────────────────────────────────────────────────
# The Gmail address you authorized via OAuth in setup.py
GMAIL_USER=you@example.com

# ── LLM backend ───────────────────────────────────────────────────────────────
# Options: anthropic | ollama
# anthropic = cloud, highest quality   ollama = local, fully private
LLM_BACKEND=anthropic

# Anthropic (used when LLM_BACKEND=anthropic)
# Get key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (used when LLM_BACKEND=ollama — nothing leaves your machine)
# Run: ollama serve && ollama pull qwen2.5:7b
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_HOST=http://localhost:11434

# ── Vault ─────────────────────────────────────────────────────────────────────
# Absolute path to your Obsidian vault folder.
# Leave blank to use ./vault/ next to this file.
VAULT_PATH=

# ── Tunables ──────────────────────────────────────────────────────────────────
# Gmail search filter ANDed with --since on every run.
# Extend with extra labels if your meeting emails land elsewhere.
GMAIL_QUERY=(category:primary OR category:personal OR label:meetings) -in:spam -in:trash
# Hard cap on messages fetched per ingest run
MAX_PER_RUN=200

# ── Jira Integration (optional) ───────────────────────────────────────────────
# Set JIRA_ENABLED=true and fill in the vars below to auto-create Jira stories
# from meeting action items. Run `python setup.py --force` for guided setup.
JIRA_ENABLED=false
JIRA_DOMAIN=                        # yourcompany.atlassian.net (no https://)
JIRA_EMAIL=                         # email used to log into Jira
JIRA_API_TOKEN=                     # https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_PROJECT_KEY=                   # e.g. PROJ, ENG, SCRUM
JIRA_BOARD_ID=                      # numeric board ID from board URL (e.g. /boards/1 → 1)
JIRA_ISSUE_TYPE=Task                # Task | Story (must match your project config)
JIRA_AUTO_PUSH=true                 # auto-push after each ingested meeting
JIRA_CREATE_DECISIONS=false         # also create issues for decisions
JIRA_DECISION_ISSUE_TYPE=Task
JIRA_ASSIGNEE_MAP={}                # JSON: {"owner name": "jira-account-id", ...}
JIRA_RESOLVE_USERS_BY_EMAIL=false   # look up accountId via Jira API when owner is an email

# ── Memgraph Integration (optional) ──────────────────────────────────────────
# Graph database layer — stores People, Meetings, Topics, Decisions, ActionItems
# as nodes with relationships. Query with Memgraph Lab at http://localhost:3000
# Docker quickstart: docker run -p 7687:7687 -p 3000:3000 memgraph/memgraph-platform
MEMGRAPH_ENABLED=false
MEMGRAPH_HOST=localhost              # Bolt host (localhost when using Docker)
MEMGRAPH_PORT=7687                   # Bolt port (Memgraph default)
MEMGRAPH_USER=                       # Leave blank for Memgraph CE (no auth by default)
MEMGRAPH_PASSWORD=                   # Leave blank for Memgraph CE

# ── Syncthing Integration (optional) ─────────────────────────────────────────
# Triggers an immediate vault folder rescan after each meeting note is written,
# so changes propagate to connected team devices without waiting for the next
# scheduled sync interval.
# Install: brew install syncthing && brew services start syncthing
# Then open http://127.0.0.1:8384 → Add Folder → point at your vault path
SYNCTHING_ENABLED=false
SYNCTHING_URL=http://127.0.0.1:8384  # Syncthing REST API base URL
SYNCTHING_API_KEY=                   # Settings → GUI → API Key in Syncthing web UI
SYNCTHING_FOLDER_ID=vault            # Folder ID assigned when you add the vault in Syncthing
