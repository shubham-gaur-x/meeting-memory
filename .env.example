# ── Composio ──────────────────────────────────────────────────────────────────
# Free API key: https://app.composio.dev → Settings → API Keys
COMPOSIO_API_KEY=
COMPOSIO_ENTITY_ID=default
# Advanced: override if using a self-hosted Composio instance
COMPOSIO_BASE_URL=https://backend.composio.dev

# ── Gmail ─────────────────────────────────────────────────────────────────────
# The Gmail address you authorized via OAuth in setup.py
GMAIL_USER=you@example.com

# ── LLM backend ───────────────────────────────────────────────────────────────
# Options: anthropic | ollama
# anthropic = cloud, highest quality   ollama = local, fully private
LLM_BACKEND=anthropic

# Anthropic (used when LLM_BACKEND=anthropic)
# Get key at https://console.anthropic.com
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (used when LLM_BACKEND=ollama — nothing leaves your machine)
# Run: ollama serve && ollama pull qwen2.5:7b
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_HOST=http://localhost:11434

# ── Vault ─────────────────────────────────────────────────────────────────────
# Absolute path to your Obsidian vault folder.
# Leave blank to use ./vault/ next to this file.
VAULT_PATH=

# ── Tunables ──────────────────────────────────────────────────────────────────
# Gmail search filter ANDed with --since on every run.
# Extend with extra labels if your meeting emails land elsewhere.
GMAIL_QUERY=(category:primary OR category:personal OR label:meetings) -in:spam -in:trash
# Hard cap on messages fetched per ingest run
MAX_PER_RUN=200
